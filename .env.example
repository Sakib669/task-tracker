# ==============================================================================
# Environment Variables Example
# ==============================================================================

# --- [MANDATORY] ---
# Database connection for pooling (e.g., Supabase, Neon)
DATABASE_URL="postgresql://user:password@host:port/database?pgbouncer=true"

# Direct database connection for running Prisma migrations
DIRECT_URL="postgresql://user:password@host:port/database"

# Authentication secret for NextAuth.js
AUTH_SECRET="generate-a-secure-random-key"

# The public URL of your application
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- [OPTIONAL / SERVICE SPECIFIC] ---

# Stripe Configuration
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_ID="price_..."

# AI APIs (Provide at least one)
GEMINI_API_KEY="your-gemini-api-key"
GROQ_API_KEY="your-groq-api-key"
